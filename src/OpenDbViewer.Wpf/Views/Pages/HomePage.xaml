<UserControl x:Class="OpenDbViewer.Shell.Views.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
             xmlns:mw="clr-namespace:Wpf.Ui.Markup;assembly=Wpf.Ui"
             mc:Ignorable="d">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="32" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="28"
                   FontWeight="SemiBold"
                   Text="Open DB Viewer" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <ui:Button MinWidth="160"
                       Content="Open database"
                       Icon="{mw:SymbolIcon Fluent24}"
                       Command="{Binding OpenDatabaseCommand}" />

            <StackPanel Grid.Column="2">
                <TextBlock Margin="0,0,0,4"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="Search recent or pinned" />
                <TextBox VerticalContentAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="4">
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Text="Pinned" />
            <ListBox Margin="0,12,0,0"
                     BorderThickness="0"
                     ItemsSource="{Binding FilteredPinnedEntries}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Padding="12"
                                    HorizontalContentAlignment="Stretch"
                                    Command="{Binding DataContext.OpenRecentCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding Name}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Text="{Binding FilePath}" />
                                </StackPanel>
                            </Button>
                            <ui:Button Grid.Column="1"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                       CommandParameter="{Binding}"
                                       Icon="{mw:SymbolIcon PinOff24}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Margin="0,20,0,0"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Text="Recent" />
            <ListBox Margin="0,12,0,0"
                     BorderThickness="0"
                     ItemsSource="{Binding FilteredRecentEntries}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Padding="12"
                                    HorizontalContentAlignment="Stretch"
                                    Command="{Binding DataContext.OpenRecentCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding Name}" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Text="{Binding FilePath}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Margin="16,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Text="{Binding LastOpenedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" />
                                </Grid>
                            </Button>
                            <ui:Button Grid.Column="1"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                       CommandParameter="{Binding}"
                                       Icon="{mw:SymbolIcon Pin24}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <TextBlock Grid.Row="6"
                   FontSize="14"
                   Text="{Binding StatusMessage}" />
    </Grid>
</UserControl>
