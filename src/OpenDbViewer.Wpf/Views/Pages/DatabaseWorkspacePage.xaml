<UserControl x:Class="OpenDbViewer.Shell.Views.Pages.DatabaseWorkspacePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
             xmlns:mw="clr-namespace:Wpf.Ui.Markup;assembly=Wpf.Ui"
             mc:Ignorable="d">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.ColumnSpan="3">
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,6,0,0"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="{Binding DatabasePath}" />
        </StackPanel>

        <Border Grid.Row="2"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Margin="0,0,0,8"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Text="对象" />
                <TreeView x:Name="ObjectTree"
                          ItemsSource="{Binding ObjectExplorer.RootNodes}"
                          SelectedItemChanged="ObjectTree_OnSelectedItemChanged">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}" />
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </DockPanel>
        </Border>

        <TabControl Grid.Row="2"
                    Grid.Column="2">
            <TabItem Header="结构">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Text="{Binding Schema.TableName}" />

                    <DataGrid Grid.Row="2"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ItemsSource="{Binding Schema.Columns}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name}" Header="列名" />
                            <DataGridTextColumn Binding="{Binding DataType}" Header="类型" />
                            <DataGridCheckBoxColumn Binding="{Binding IsNullable}" Header="可空" />
                            <DataGridCheckBoxColumn Binding="{Binding IsPrimaryKey}" Header="主键" />
                            <DataGridTextColumn Binding="{Binding DefaultValue}" Header="默认值" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="数据">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="上一页"
                                   Command="{Binding Data.LoadPreviousPageCommand}"
                                   Icon="{mw:SymbolIcon ArrowLeft24}" />
                        <ui:Button Margin="8,0,12,0"
                                   Content="下一页"
                                   Command="{Binding Data.LoadNextPageCommand}"
                                   Icon="{mw:SymbolIcon ArrowRight24}" />
                        <TextBlock VerticalAlignment="Center"
                                   Text="每页" />
                        <ComboBox Margin="8,0,12,0"
                                  Width="88"
                                  ItemsSource="{Binding Data.PageSizeOptions}"
                                  SelectionChanged="PageSizeComboBox_OnSelectionChanged"
                                  SelectedItem="{Binding Data.PageSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock FontWeight="SemiBold"
                                   Text="第 " />
                        <TextBlock FontWeight="SemiBold"
                                   Text="{Binding Data.PageNumber}" />
                        <TextBlock FontWeight="SemiBold"
                                   Text=" 页" />
                        <TextBlock Margin="16,0,0,0"
                                   Text="{Binding Data.Rows.Count, StringFormat=行数: {0}}" />
                        <TextBlock Margin="16,0,0,0"
                                   Text="{Binding Data.HasNextPage, StringFormat=更多: {0}}" />
                    </StackPanel>

                    <DataGrid Grid.Row="2"
                              x:Name="DataGridView"
                              AutoGenerateColumns="True"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              Sorting="DataGridView_OnSorting"
                              ItemsSource="{Binding Data.TableView}" />
                </Grid>
            </TabItem>
            <TabItem Header="查询">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="140" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="执行"
                                   Command="{Binding Query.ExecuteQueryCommand}"
                                   Icon="{mw:SymbolIcon Play24}" />
                        <ui:Button Margin="8,0,0,0"
                                   Content="导出 CSV"
                                   Command="{Binding Query.ExportResultsCommand}"
                                   Icon="{mw:SymbolIcon ArrowExportLtr24}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="{Binding Query.CurrentTableName, StringFormat=当前表: {0}}" />
                            <ui:Button Margin="12,0,0,0"
                                       Content="Select 100"
                                       Command="{Binding Query.UseSelectTemplateCommand}" />
                            <ui:Button Margin="8,0,0,0"
                                       Content="Count"
                                       Command="{Binding Query.UseCountTemplateCommand}" />
                            <ui:Button Margin="8,0,0,0"
                                       Content="Schema"
                                       Command="{Binding Query.UseSchemaTemplateCommand}" />
                        </StackPanel>

                        <TextBox AcceptsReturn="True"
                                 HorizontalScrollBarVisibility="Auto"
                                 Text="{Binding Query.QueryText, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="14"
                                 TextWrapping="NoWrap" />
                    </StackPanel>

                    <TextBlock Grid.Row="4"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding Query.StatusMessage}" />

                    <DataGrid Grid.Row="6"
                              AutoGenerateColumns="True"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              ItemsSource="{Binding Query.ResultView}" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
