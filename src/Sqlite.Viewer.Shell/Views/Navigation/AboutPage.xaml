<UserControl
    x:Class="Sqlite.Viewer.Shell.Views.Navigation.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="640"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Border
                Padding="28"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                BorderThickness="1"
                CornerRadius="20"
                MaxWidth="760"
                HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="{Binding Title}" />
                    <TextBlock
                        Margin="0,16,0,0"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="{Binding ProductName}" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding ProductSubtitle}" />
                    <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                        <Border
                            Padding="10,4"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <TextBlock FontWeight="SemiBold" Text="{Binding VersionDisplay}" />
                        </Border>
                        <TextBlock
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                            Text="{Binding FrameworkDisplay}" />
                    </StackPanel>
                    <TextBlock
                        Margin="0,20,0,0"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="{Binding Description}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Margin="0,20,0,0"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="版本说明" />
                    <TextBlock
                        Margin="0,8,0,0"
                        FontFamily="Consolas"
                        FontSize="13"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding ChangelogSummary}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Margin="0,20,0,0"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                        Text="已知限制" />
                    <TextBlock
                        Margin="0,8,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding KnownLimitations}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Margin="0,24,0,0"
                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                        Text="{Binding Copyright}" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
