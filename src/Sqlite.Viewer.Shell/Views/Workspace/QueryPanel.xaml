<UserControl
    x:Class="Sqlite.Viewer.Shell.Views.Workspace.QueryPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="WorkspaceStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
                                            <Grid Margin="0,12,0,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="12" />
                                                    <RowDefinition Height="170" />
                                                    <RowDefinition Height="12" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="12" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>
                                                <Border Padding="12" Style="{StaticResource WorkspaceContentCardStyle}">
                                                    <WrapPanel>
                                                        <ui:Button
                                                            Command="{Binding Query.ExecuteQueryCommand}"
                                                            Content="执行全部"
                                                            Icon="{ui:SymbolIcon Play24}" />
                                                        <ui:Button
                                                            Margin="8,0,0,0"
                                                            Appearance="Secondary"
                                                            Command="{Binding Query.ExecuteCurrentStatementCommand}"
                                                            Content="执行当前语句" />
                                                        <ui:Button
                                                            Margin="8,0,0,0"
                                                            Appearance="Secondary"
                                                            Command="{Binding Query.ExplainCurrentStatementCommand}"
                                                            Content="EXPLAIN" />
                                                        <ui:Button
                                                            Margin="8,0,0,0"
                                                            Appearance="Secondary"
                                                            Command="{Binding Query.CancelQueryCommand}"
                                                            Content="取消"
                                                            Icon="{ui:SymbolIcon Dismiss24}" />
                                                        <ui:Button
                                                            Margin="8,0,0,0"
                                                            Command="{Binding Query.ExportResultsCommand}"
                                                            Content="导出已加载结果"
                                                            Icon="{ui:SymbolIcon ArrowExportLtr24}"
                                                            ToolTip="仅导出当前结果网格中的行（受查询行数上限约束，不重跑 SQL）" />
                                                        <ui:Button
                                                            Margin="8,0,0,0"
                                                            Command="{Binding Query.ToggleWriteModeCommand}"
                                                            Content="{Binding Query.ToggleWriteModeText}" />
                                                        <TextBlock
                                                            Margin="16,0,0,0"
                                                            VerticalAlignment="Center"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding Query.QueryAccessModeLabel}" />
                                                        <TextBlock
                                                            Margin="8,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                            MaxWidth="360"
                                                            TextWrapping="Wrap"
                                                            Text="{Binding Query.QueryAccessModeSummary}" />
                                                        <TextBlock
                                                            Margin="16,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Text="{Binding Query.CurrentTableName, StringFormat=当前数据表：{0}}" />
                                                    </WrapPanel>
                                                </Border>
                                                <StackPanel Grid.Row="1">
                                                    <Border
                                                        Margin="0,8,0,0"
                                                        Padding="12,8"
                                                        Background="#FFF8E5"
                                                        CornerRadius="8"
                                                        Visibility="{Binding Query.ShowWriteWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Orientation="Horizontal">
                                                                <ui:SymbolIcon
                                                                    Margin="0,1,8,0"
                                                                    Foreground="#CC8B00"
                                                                    Symbol="Warning24" />
                                                                <TextBlock
                                                                    VerticalAlignment="Center"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="#6B4D00"
                                                                    Text="{Binding Query.WriteModeBannerText}"
                                                                    TextWrapping="Wrap" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                <CheckBox
                                                                    Margin="0,0,12,0"
                                                                    VerticalAlignment="Center"
                                                                    Content="本会话不再确认高风险"
                                                                    Foreground="#6B4D00"
                                                                    IsChecked="{Binding Query.SkipHighRiskConfirmThisSession, Mode=TwoWay}" />
                                                                <ui:Button
                                                                    Appearance="Transparent"
                                                                    Command="{Binding Query.ToggleWriteModeCommand}"
                                                                    Content="切回只读"
                                                                    Foreground="#6B4D00" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                    <Border
                                                        Margin="0,8,0,0"
                                                        Padding="12,8"
                                                        Background="#E8F4FF"
                                                        CornerRadius="8"
                                                        Visibility="{Binding Query.ShowTruncationBanner, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <ui:SymbolIcon
                                                                Margin="0,1,8,0"
                                                                Foreground="#0067C0"
                                                                Symbol="Info24" />
                                                            <TextBlock
                                                                VerticalAlignment="Center"
                                                                Foreground="#003A6B"
                                                                Text="查询结果已达设置中的行数上限，仅显示部分行。可在「设置」中调整上限。"
                                                                TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                                <Border
                                                    Grid.Row="3"
                                                    Padding="14"
                                                    Style="{StaticResource WorkspaceContentCardStyle}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="10" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <StackPanel Orientation="Horizontal">
                                                            <ComboBox
                                                                Width="220"
                                                                Margin="0,0,8,0"
                                                                DisplayMemberPath="Sql"
                                                                ItemsSource="{Binding Query.RecentHistory}"
                                                                SelectedItem="{Binding Query.SelectedHistoryEntry, Mode=TwoWay}"
                                                                ToolTip="最近执行的 SQL（选择后填入编辑器）" />
                                                            <ComboBox
                                                                Width="180"
                                                                Margin="0,0,8,0"
                                                                DisplayMemberPath="Sql"
                                                                ItemsSource="{Binding Query.Favorites}"
                                                                SelectedItem="{Binding Query.SelectedFavoriteEntry, Mode=TwoWay}"
                                                                ToolTip="收藏的 SQL（选择后填入编辑器）" />
                                                            <ui:Button
                                                                Margin="0,0,8,0"
                                                                Appearance="Secondary"
                                                                Command="{Binding Query.FavoriteCurrentQueryCommand}"
                                                                Content="收藏当前" />
                                                            <ui:Button Command="{Binding Query.UseSelectTemplateCommand}" Content="查询前 100 行" />
                                                            <ui:Button
                                                                Margin="8,0,0,0"
                                                                Command="{Binding Query.UseCountTemplateCommand}"
                                                                Content="统计行数" />
                                                            <ui:Button
                                                                Margin="8,0,0,0"
                                                                Command="{Binding Query.UseSchemaTemplateCommand}"
                                                                Content="表结构" />
                                                        </StackPanel>
                                                        <TextBox
                                                            Grid.Row="2"
                                                            Padding="10"
                                                            AcceptsReturn="True"
                                                            Background="{DynamicResource ControlFillColorInputActiveBrush}"
                                                            BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                                            BorderThickness="1"
                                                            CaretBrush="{DynamicResource AccentFillColorDefaultBrush}"
                                                            FontFamily="Consolas"
                                                            FontSize="14"
                                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                            HorizontalScrollBarVisibility="Auto"
                                                            Text="{Binding Query.QueryText, UpdateSourceTrigger=PropertyChanged}"
                                                            TextWrapping="NoWrap"
                                                            VerticalScrollBarVisibility="Auto" />
                                                    </Grid>
                                                </Border>
                                                <Border
                                                    Grid.Row="5"
                                                    Padding="12"
                                                    Style="{StaticResource WorkspaceContentCardStyle}">
                                                    <StackPanel>
                                                        <TextBlock
                                                            d:Text="返回 50 行"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding Query.ResultSummary}" />
                                                        <TextBlock Margin="0,6,0,0" Text="{Binding Query.StatusMessage}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border
                                                    Grid.Row="7"
                                                    Padding="14"
                                                    Style="{StaticResource WorkspaceContentCardStyle}">
                                                    <Grid>
                                                        <DataGrid
                                                            AutoGenerateColumns="True"
                                                            AutoGeneratingColumn="OnAutoGeneratingColumn"
                                                            CanUserAddRows="False"
                                                            CellStyle="{StaticResource WorkspaceDataGridCellStyle}"
                                                            ColumnHeaderStyle="{StaticResource WorkspaceDataGridColumnHeaderStyle}"
                                                            IsReadOnly="True"
                                                            ItemsSource="{Binding Query.ResultView}"
                                                            RowStyle="{StaticResource WorkspaceDataGridRowStyle}"
                                                            Style="{StaticResource WorkspaceDataGridStyle}"
                                                            Visibility="{Binding Query.ShowResultGrid, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                        <StackPanel
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding Query.ShowEmptyResultState, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <TextBlock
                                                                FontSize="18"
                                                                FontWeight="SemiBold"
                                                                Text="暂无查询结果" />
                                                            <TextBlock Margin="0,8,0,0" Text="执行当前 SQL 后，这里会显示数据行或命令反馈。" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </Grid>
</UserControl>
