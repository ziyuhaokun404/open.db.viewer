<UserControl
    x:Class="Sqlite.Viewer.Shell.Views.Workspace.ObjectExplorerPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="WorkspaceStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </UserControl.Resources>
    <Border Padding="12" Style="{StaticResource WorkspacePanelStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock
                                        FontSize="17"
                                        Style="{StaticResource WorkspaceSectionTitleStyle}"
                                        Text="对象" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        Style="{StaticResource WorkspaceMutedTextStyle}"
                                        Text="浏览表、视图、索引与触发器。" />
                                    <CheckBox
                                        Margin="0,8,0,0"
                                        Content="显示系统表"
                                        IsChecked="{Binding ObjectExplorer.ShowSystemObjects, Mode=TwoWay}" />
                                </StackPanel>
                                <Border Grid.Row="2" Style="{StaticResource WorkspaceInputBorderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                            Symbol="Search24" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            IsHitTestVisible="False"
                                            Text="筛选对象...">
                                            <TextBlock.Style>
                                                <Style BasedOn="{StaticResource WorkspaceCaptionStyle}" TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ObjectExplorer.SearchText}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ObjectExplorer.SearchText}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox
                                            Grid.Column="1"
                                            Margin="10,0"
                                            VerticalContentAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                            Text="{Binding ObjectExplorer.SearchText, UpdateSourceTrigger=PropertyChanged}" />
                                        <ui:Button
                                            Grid.Column="2"
                                            Width="28"
                                            Height="28"
                                            Margin="6,0,0,0"
                                            Padding="0"
                                            Appearance="Transparent"
                                            Command="{Binding ObjectExplorer.ClearSearchCommand}"
                                            Icon="{ui:SymbolIcon Dismiss24}"
                                            Visibility="{Binding ObjectExplorer.HasSearchText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <ui:Button
                                            Grid.Column="3"
                                            Margin="6,0,0,0"
                                            Appearance="Transparent"
                                            Icon="{ui:SymbolIcon Filter24}"
                                            Style="{StaticResource WorkspaceIconButtonStyle}" />
                                    </Grid>
                                </Border>
                                <DockPanel Grid.Row="4" LastChildFill="False">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon
                                            Width="13"
                                            Height="13"
                                            Margin="0,2,5,0"
                                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                            Symbol="ChevronDown16" />
                                        <TextBlock
                                            d:Text="对象"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Text="{Binding ObjectExplorer.GroupTitle}" />
                                    </StackPanel>
                                    <Border
                                        Padding="7,2"
                                        DockPanel.Dock="Right"
                                        Style="{StaticResource WorkspaceStatusPillStyle}">
                                        <TextBlock
                                            d:Text="3"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                            Text="{Binding ObjectExplorer.FilteredObjectCount}" />
                                    </Border>
                                </DockPanel>
                                <Border
                                    Grid.Row="6"
                                    Padding="4"
                                    Style="{StaticResource WorkspaceContentCardStyle}">
                                    <Grid>
                                        <ListBox
                                            x:Name="ObjectList"
                                            d:ItemsSource="{d:SampleData ItemCount=5}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            ItemContainerStyle="{StaticResource ObjectListBoxItemStyle}"
                                            ItemsSource="{Binding ObjectExplorer.FilteredTables}"
                                            SelectedItem="{Binding ObjectExplorer.SelectedNode, Mode=TwoWay}"
                                            SelectionChanged="ObjectList_OnSelectionChanged">
                                            <ListBox.ContextMenu>
                                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                    <MenuItem
                                                        Command="{Binding CopySelectedObjectNameCommand}"
                                                        Header="复制名称" />
                                                    <MenuItem
                                                        Command="{Binding CopySelectedObjectSqlCommand}"
                                                        Header="复制 DDL" />
                                                    <MenuItem
                                                        Command="{Binding OpenSelectedInQueryCommand}"
                                                        Header="在查询中打开" />
                                                    <Separator />
                                                    <MenuItem
                                                        Command="{Binding RefreshCommand}"
                                                        Header="刷新" />
                                                </ContextMenu>
                                            </ListBox.ContextMenu>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <ui:SymbolIcon
                                                            Width="16"
                                                            Height="16"
                                                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                            Symbol="TableSimple24" />
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock
                                                                FontSize="13"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                Text="{Binding Name}" />
                                                            <TextBlock
                                                                FontSize="11"
                                                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                Text="{Binding Subtitle}" />
                                                        </StackPanel>
                                                        <ui:SymbolIcon
                                                            x:Name="ItemStarIcon"
                                                            Grid.Column="3"
                                                            Width="14"
                                                            Height="14"
                                                            VerticalAlignment="Center"
                                                            Opacity="0"
                                                            Symbol="Star24" />
                                                    </Grid>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                            <Setter TargetName="ItemStarIcon" Property="Opacity" Value="1" />
                                                            <Setter TargetName="ItemStarIcon" Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource ShowWhenNoFilteredTablesStyle}">
                                            <ui:SymbolIcon
                                                HorizontalAlignment="Center"
                                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                Symbol="Search24" />
                                            <TextBlock
                                                Margin="0,10,0,0"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                Text="没有匹配的对象" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <TextBlock
                                    Grid.Row="7"
                                    Margin="0,8,0,0"
                                    d:Text="共 3 个对象"
                                    Style="{StaticResource WorkspaceMutedTextStyle}"
                                    Text="{Binding ObjectExplorer.FooterSummary}" />
                            </Grid>
    </Border>
</UserControl>
