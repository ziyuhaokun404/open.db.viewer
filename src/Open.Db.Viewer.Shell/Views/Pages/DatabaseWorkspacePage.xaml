<UserControl x:Class="Open.Db.Viewer.Shell.Views.Pages.DatabaseWorkspacePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:mw="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="PanelBorderStyle"
               TargetType="Border">
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>

        <Style x:Key="HideWhenTableSelectedStyle"
               TargetType="StackPanel">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasTableSelection}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="26"
                               FontWeight="SemiBold"
                               Text="{Binding Title}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding DatabasePath}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="{Binding StatusMessage}" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <ui:Button Content="Home"
                               Command="{Binding ReturnHomeCommand}"
                               Icon="{mw:SymbolIcon ArrowReply24}" />
                    <ui:Button Margin="8,0,0,0"
                               Content="Refresh"
                               Command="{Binding RefreshCommand}"
                               Icon="{mw:SymbolIcon ArrowClockwise24}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelBorderStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top"
                                Margin="0,0,0,14">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Objects" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="Browse tables in the current database." />
                    </StackPanel>

                    <TreeView x:Name="ObjectTree"
                              ItemsSource="{Binding ObjectExplorer.RootNodes}"
                              SelectedItemChanged="ObjectTree_OnSelectedItemChanged">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Name}" />
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Text="{Binding SelectedObjectTitle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="{Binding SelectedObjectSubtitle}" />
                    </StackPanel>

                    <TabControl Grid.Row="2"
                                Visibility="{Binding HasTableSelection, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TabItem Header="Schema">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Padding="14"
                                        Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Schema.TableName}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Text="{Binding Schema.ColumnCountSummary}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2"
                                        Padding="12"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <DataGrid AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              IsReadOnly="True"
                                              ItemsSource="{Binding Schema.Columns}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Binding="{Binding Name}" Header="Column" />
                                            <DataGridTextColumn Binding="{Binding DataType}" Header="Type" />
                                            <DataGridCheckBoxColumn Binding="{Binding IsNullable}" Header="Nullable" />
                                            <DataGridCheckBoxColumn Binding="{Binding IsPrimaryKey}" Header="Primary key" />
                                            <DataGridTextColumn Binding="{Binding DefaultValue}" Header="Default" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </Grid>
                        </TabItem>
                        <TabItem Header="Data">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Padding="14"
                                        Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <WrapPanel>
                                        <ui:Button Content="Previous"
                                                   Command="{Binding Data.LoadPreviousPageCommand}"
                                                   Icon="{mw:SymbolIcon ArrowLeft24}" />
                                        <ui:Button Margin="8,0,0,0"
                                                   Content="Next"
                                                   Command="{Binding Data.LoadNextPageCommand}"
                                                   Icon="{mw:SymbolIcon ArrowRight24}" />
                                        <ui:Button Margin="8,0,0,0"
                                                   Content="Refresh"
                                                   Command="{Binding Data.RefreshCurrentPageCommand}"
                                                   Icon="{mw:SymbolIcon ArrowClockwise24}" />
                                        <ui:Button Margin="8,0,0,0"
                                                   Content="Export CSV"
                                                   Command="{Binding Data.ExportCurrentPageCommand}"
                                                   Icon="{mw:SymbolIcon ArrowExportLtr24}" />
                                        <TextBlock Margin="16,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Text="Rows per page" />
                                        <ComboBox Margin="8,0,0,0"
                                                  Width="96"
                                                  ItemsSource="{Binding Data.PageSizeOptions}"
                                                  SelectionChanged="PageSizeComboBox_OnSelectionChanged"
                                                  SelectedItem="{Binding Data.PageSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Margin="16,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Data.ResultSummary}" />
                                        <TextBlock Margin="16,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Text="{Binding Data.SortSummary}" />
                                    </WrapPanel>
                                </Border>

                                <Border Grid.Row="2"
                                        Padding="12"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="12" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Text="{Binding Data.StatusMessage}" />

                                        <DataGrid Grid.Row="2"
                                                  x:Name="DataGridView"
                                                  AutoGenerateColumns="True"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="True"
                                                  Sorting="DataGridView_OnSorting"
                                                  ItemsSource="{Binding Data.TableView}" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>
                        <TabItem Header="Query">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="140" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Padding="14"
                                        Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <WrapPanel>
                                        <ui:Button Content="Execute"
                                                   Command="{Binding Query.ExecuteQueryCommand}"
                                                   Icon="{mw:SymbolIcon Play24}" />
                                        <ui:Button Margin="8,0,0,0"
                                                   Content="Export CSV"
                                                   Command="{Binding Query.ExportResultsCommand}"
                                                   Icon="{mw:SymbolIcon ArrowExportLtr24}" />
                                        <TextBlock Margin="16,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Text="{Binding Query.CurrentTableName, StringFormat=Current table: {0}}" />
                                    </WrapPanel>
                                </Border>

                                <Border Grid.Row="2"
                                        Padding="12"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Orientation="Horizontal">
                                            <ui:Button Content="Select 100"
                                                       Command="{Binding Query.UseSelectTemplateCommand}" />
                                            <ui:Button Margin="8,0,0,0"
                                                       Content="Count"
                                                       Command="{Binding Query.UseCountTemplateCommand}" />
                                            <ui:Button Margin="8,0,0,0"
                                                       Content="Schema"
                                                       Command="{Binding Query.UseSchemaTemplateCommand}" />
                                        </StackPanel>

                                        <TextBox Grid.Row="2"
                                                 AcceptsReturn="True"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 Text="{Binding Query.QueryText, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalScrollBarVisibility="Auto"
                                                 FontFamily="Consolas"
                                                 FontSize="14"
                                                 TextWrapping="NoWrap" />
                                    </Grid>
                                </Border>

                                <Border Grid.Row="4"
                                        Padding="12"
                                        Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding Query.ResultSummary}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Text="{Binding Query.StatusMessage}" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="6"
                                        Padding="12"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <Grid>
                                        <DataGrid AutoGenerateColumns="True"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="True"
                                                  ItemsSource="{Binding Query.ResultView}"
                                                  Visibility="{Binding Query.ShowResultGrid, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                        <StackPanel Visibility="{Binding Query.ShowEmptyResultState, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Text="No query results yet" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Text="Run the current SQL to see rows or command feedback here." />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>

                    <StackPanel Grid.Row="2"
                                Style="{StaticResource HideWhenTableSelectedStyle}">
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Text="Choose a table from the left" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="Schema, data, and query tools will appear here when a table is selected." />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
