<UserControl x:Class="Open.Db.Viewer.Shell.Views.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:mw="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="SectionTitleStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="28"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                BorderThickness="1"
                CornerRadius="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="30"
                               FontWeight="SemiBold"
                               Text="Open.db.viewer" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Text="浏览本地 SQLite 文件，查看表结构，执行快速 SQL，并导出结果。" />
                </StackPanel>

                <ui:Button Grid.Column="2"
                           MinWidth="180"
                           Height="44"
                           VerticalAlignment="Center"
                           Appearance="Primary"
                           Content="打开数据库"
                           Command="{Binding OpenDatabaseCommand}"
                           Icon="{mw:SymbolIcon FolderOpen24}" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Padding="18"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <StackPanel>
                <TextBlock FontWeight="SemiBold"
                           Text="查找已保存的数据库" />
                <TextBlock Margin="0,4,0,12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="{Binding SearchSummary}" />
                <TextBox VerticalContentAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="4">
            <Grid.Resources>
                <Style TargetType="Border"
                       x:Key="PanelBorderStyle">
                    <Setter Property="Padding" Value="18" />
                    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="CornerRadius" Value="18" />
                </Style>
                <Style x:Key="EntryButtonStyle"
                       TargetType="Button">
                    <Setter Property="Padding" Value="14" />
                    <Setter Property="Margin" Value="0,0,0,10" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
                    <Setter Property="BorderThickness" Value="1" />
                </Style>
            </Grid.Resources>

            <StackPanel Visibility="{Binding ShowFirstRunState, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Text="从一个 SQLite 文件开始" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="先打开一个本地数据库，最近使用和固定列表会自动显示在这里。" />
            </StackPanel>

            <StackPanel Visibility="{Binding ShowNoResultsState, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Text="没有匹配的数据库" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="请尝试其他数据库名称或文件路径关键词。" />
            </StackPanel>

            <Grid Visibility="{Binding HasVisibleEntries, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top"
                                    Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="已固定" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="把最常用的数据库固定在这里，方便快速进入。" />
                        </StackPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding FilteredPinnedEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Button Style="{StaticResource EntryButtonStyle}"
                                                    Command="{Binding DataContext.OpenRecentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding Name}" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Text="{Binding FilePath}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Button>

                                            <ui:Button Grid.Column="1"
                                                       Margin="10,0,0,10"
                                                       VerticalAlignment="Center"
                                                       Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       CommandParameter="{Binding}"
                                                       Icon="{mw:SymbolIcon PinOff24}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource PanelBorderStyle}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top"
                                    Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="最近使用" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="快速返回最近打开过的数据库。" />
                        </StackPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding FilteredRecentEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Button Style="{StaticResource EntryButtonStyle}"
                                                    Command="{Binding DataContext.OpenRecentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock FontWeight="SemiBold"
                                                                   Text="{Binding Name}" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   Text="{Binding FilePath}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="1"
                                                               Margin="16,0,0,0"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Text="{Binding LastOpenedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" />
                                                </Grid>
                                            </Button>

                                            <ui:Button Grid.Column="1"
                                                       Margin="10,0,0,10"
                                                       VerticalAlignment="Center"
                                                       Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       CommandParameter="{Binding}"
                                                       Icon="{mw:SymbolIcon Pin24}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="6"
                Padding="14"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                BorderThickness="1"
                CornerRadius="14">
            <TextBlock Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Text="{Binding StatusMessage}" />
        </Border>
    </Grid>
</UserControl>
