<UserControl
    x:Class="Open.Db.Viewer.Shell.Views.Workspace.WorkspaceHostPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="WorkspaceSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
        <Style x:Key="WorkspacePanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
        <Style x:Key="WorkspaceContentCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
        <Style x:Key="WorkspaceDividerStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceStrokeColorDefaultBrush}" />
        </Style>
        <Style x:Key="WorkspacePageTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="WorkspaceSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>
        <Style x:Key="WorkspaceCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="WorkspaceMutedTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="WorkspaceInputBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorInputActiveBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Height" Value="38" />
        </Style>
        <Style x:Key="WorkspaceMetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Padding" Value="12,10" />
        </Style>
        <Style x:Key="WorkspaceChipStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="9,3" />
        </Style>
        <Style
            x:Key="WorkspaceStatusPillStyle"
            BasedOn="{StaticResource WorkspaceChipStyle}"
            TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorDefaultBrush}" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="WorkspaceIconTileStyle" TargetType="Border">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style
            x:Key="WorkspaceToolbarButtonStyle"
            BasedOn="{StaticResource {x:Type ui:Button}}"
            TargetType="ui:Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
        <Style
            x:Key="WorkspaceIconButtonStyle"
            BasedOn="{StaticResource {x:Type ui:Button}}"
            TargetType="ui:Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="WorkspaceTabItemStyle" TargetType="TabItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,18,0" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border
                            x:Name="TabBorder"
                            Padding="0,8,6,10"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0,0,0,2">
                            <ContentPresenter
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WorkspaceDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="RowBackground" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
            <Setter Property="AlternationCount" Value="2" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="SelectionMode" Value="Extended" />
            <Setter Property="SelectionUnit" Value="FullRow" />
        </Style>
        <Style x:Key="WorkspaceDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorTertiaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>
        <Style x:Key="WorkspaceDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="WorkspaceDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ObjectListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border
                            x:Name="ItemBorder"
                            Margin="0,0,0,3"
                            Padding="8,6"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="7">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HideWhenTableSelectedStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasTableSelection}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ShowWhenNoFilteredTablesStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ObjectExplorer.HasFilteredTables}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DataGridTextCellStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ShowWhenSearchEmptyStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ObjectExplorer.SearchText}" Value="">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ObjectExplorer.SearchText}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid Visibility="{Binding HasOpenDatabase, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border>
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="16" Style="{StaticResource WorkspaceSurfaceStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Width="44"
                                Height="44"
                                Style="{StaticResource WorkspaceIconTileStyle}">
                                <ui:SymbolIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Symbol="Database24" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,24,0">
                                <TextBlock
                                    d:Text="示例数据库"
                                    Style="{StaticResource WorkspacePageTitleStyle}"
                                    Text="{Binding Title}" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    d:Text="C:\Users\demo\app.db"
                                    Style="{StaticResource WorkspaceMutedTextStyle}"
                                    Text="{Binding DatabasePath}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <StackPanel
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <ui:Button
                                    Margin="0,0,10,0"
                                    Appearance="Secondary"
                                    Command="{Binding ReturnHomeCommand}"
                                    Content="返回首页"
                                    Icon="{ui:SymbolIcon ArrowReply24}"
                                    Style="{StaticResource WorkspaceToolbarButtonStyle}" />
                                <ui:Button
                                    Margin="0,0,10,0"
                                    Appearance="Secondary"
                                    Command="{Binding RefreshCommand}"
                                    Content="刷新"
                                    Icon="{ui:SymbolIcon ArrowClockwise24}"
                                    Style="{StaticResource WorkspaceToolbarButtonStyle}" />
                                <Border Width="280" Style="{StaticResource WorkspaceInputBorderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon VerticalAlignment="Center" Symbol="Search24" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            IsHitTestVisible="False"
                                            Text="搜索对象 (Ctrl+F)">
                                            <TextBlock.Style>
                                                <Style BasedOn="{StaticResource WorkspaceCaptionStyle}" TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ObjectExplorer.SearchText}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ObjectExplorer.SearchText}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox
                                            Grid.Column="1"
                                            Margin="10,0"
                                            VerticalContentAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                            Text="{Binding ObjectExplorer.SearchText, UpdateSourceTrigger=PropertyChanged}" />
                                        <ui:Button
                                            Grid.Column="2"
                                            Width="28"
                                            Height="28"
                                            Padding="0"
                                            Appearance="Transparent"
                                            Command="{Binding ObjectExplorer.ClearSearchCommand}"
                                            Icon="{ui:SymbolIcon Dismiss24}"
                                            Visibility="{Binding ObjectExplorer.HasSearchText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </Grid>
                                </Border>
                                <ui:Button
                                    Margin="10,0,0,0"
                                    Appearance="Secondary"
                                    Icon="{ui:SymbolIcon Filter24}"
                                    Style="{StaticResource WorkspaceIconButtonStyle}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Padding="12" Style="{StaticResource WorkspacePanelStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock
                                        FontSize="17"
                                        Style="{StaticResource WorkspaceSectionTitleStyle}"
                                        Text="对象" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        Style="{StaticResource WorkspaceMutedTextStyle}"
                                        Text="浏览当前数据库中的数据表。" />
                                </StackPanel>
                                <Border Grid.Row="2" Style="{StaticResource WorkspaceInputBorderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                            Symbol="Search24" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            IsHitTestVisible="False"
                                            Text="筛选表名...">
                                            <TextBlock.Style>
                                                <Style BasedOn="{StaticResource WorkspaceCaptionStyle}" TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ObjectExplorer.SearchText}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ObjectExplorer.SearchText}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox
                                            Grid.Column="1"
                                            Margin="10,0"
                                            VerticalContentAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                            Text="{Binding ObjectExplorer.SearchText, UpdateSourceTrigger=PropertyChanged}" />
                                        <ui:Button
                                            Grid.Column="2"
                                            Width="28"
                                            Height="28"
                                            Margin="6,0,0,0"
                                            Padding="0"
                                            Appearance="Transparent"
                                            Command="{Binding ObjectExplorer.ClearSearchCommand}"
                                            Icon="{ui:SymbolIcon Dismiss24}"
                                            Visibility="{Binding ObjectExplorer.HasSearchText, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <ui:Button
                                            Grid.Column="3"
                                            Margin="6,0,0,0"
                                            Appearance="Transparent"
                                            Icon="{ui:SymbolIcon Filter24}"
                                            Style="{StaticResource WorkspaceIconButtonStyle}" />
                                    </Grid>
                                </Border>
                                <DockPanel Grid.Row="4" LastChildFill="False">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon
                                            Width="13"
                                            Height="13"
                                            Margin="0,2,5,0"
                                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                            Symbol="ChevronDown16" />
                                        <TextBlock
                                            d:Text="表"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Text="{Binding ObjectExplorer.GroupTitle}" />
                                    </StackPanel>
                                    <Border
                                        Padding="7,2"
                                        DockPanel.Dock="Right"
                                        Style="{StaticResource WorkspaceStatusPillStyle}">
                                        <TextBlock
                                            d:Text="3"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                            Text="{Binding ObjectExplorer.FilteredObjectCount}" />
                                    </Border>
                                </DockPanel>
                                <Border
                                    Grid.Row="6"
                                    Padding="4"
                                    Style="{StaticResource WorkspaceContentCardStyle}">
                                    <Grid>
                                        <ListBox
                                            x:Name="ObjectList"
                                            d:ItemsSource="{d:SampleData ItemCount=5}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            ItemContainerStyle="{StaticResource ObjectListBoxItemStyle}"
                                            ItemsSource="{Binding ObjectExplorer.FilteredTables}"
                                            SelectedItem="{Binding ObjectExplorer.SelectedNode, Mode=TwoWay}"
                                            SelectionChanged="ObjectList_OnSelectionChanged">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <ui:SymbolIcon
                                                            Width="16"
                                                            Height="16"
                                                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                            Symbol="TableSimple24" />
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock
                                                                FontSize="13"
                                                                FontWeight="SemiBold"
                                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                Text="{Binding Name}" />
                                                            <TextBlock
                                                                FontSize="11"
                                                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                Text="SQLite 表" />
                                                        </StackPanel>
                                                        <ui:SymbolIcon
                                                            x:Name="ItemStarIcon"
                                                            Grid.Column="3"
                                                            Width="14"
                                                            Height="14"
                                                            VerticalAlignment="Center"
                                                            Opacity="0"
                                                            Symbol="Star24" />
                                                    </Grid>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                            <Setter TargetName="ItemStarIcon" Property="Opacity" Value="1" />
                                                            <Setter TargetName="ItemStarIcon" Property="Foreground" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource ShowWhenNoFilteredTablesStyle}">
                                            <ui:SymbolIcon
                                                HorizontalAlignment="Center"
                                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                Symbol="Search24" />
                                            <TextBlock
                                                Margin="0,10,0,0"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                Text="没有匹配的表" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <TextBlock
                                    Grid.Row="7"
                                    Margin="0,8,0,0"
                                    d:Text="共 3 个对象"
                                    Style="{StaticResource WorkspaceMutedTextStyle}"
                                    Text="{Binding ObjectExplorer.FooterSummary}" />
                            </Grid>
                        </Border>

                        <Border
                            Grid.Column="2"
                            Padding="0"
                            Style="{StaticResource WorkspacePanelStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="1" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid Margin="16,14,16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                d:Text="users"
                                                Style="{StaticResource WorkspacePageTitleStyle}"
                                                Text="{Binding SelectedObjectTitle}" />
                                            <Border Margin="10,3,0,0" Style="{StaticResource WorkspaceChipStyle}">
                                                <TextBlock
                                                    d:Text="表 (TABLE)"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                    Text="{Binding SelectedObjectKindLabel}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock
                                            Margin="0,6,0,0"
                                            d:Text="5 列 · 1,234 行 · 2 索引"
                                            Style="{StaticResource WorkspaceMutedTextStyle}"
                                            Text="{Binding SelectedObjectSubtitle}" />
                                    </StackPanel>
                                    <Border
                                        Grid.Column="1"
                                        Padding="12,10"
                                        Style="{StaticResource WorkspaceMetricCardStyle}">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource WorkspaceCaptionStyle}" Text="数据库引擎" />
                                            <TextBlock
                                                Margin="0,4,0,0"
                                                d:Text="SQLite 3.42.0"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                Text="{Binding Schema.SqliteVersion, StringFormat=SQLite {0}}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <Border Grid.Row="1" Style="{StaticResource WorkspaceDividerStyle}" />
                                <Grid Grid.Row="2" Visibility="{Binding HasTableSelection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TabControl
                                        Margin="8"
                                        Background="Transparent"
