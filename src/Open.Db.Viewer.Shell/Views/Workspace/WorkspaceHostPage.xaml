                                                            ItemsSource="{Binding Query.ResultView}"
                                                            RowStyle="{StaticResource WorkspaceDataGridRowStyle}"
                                                            Style="{StaticResource WorkspaceDataGridStyle}"
                                                            Visibility="{Binding Query.ShowResultGrid, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                        <StackPanel
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding Query.ShowEmptyResultState, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <TextBlock
                                                                FontSize="18"
                                                                FontWeight="SemiBold"
                                                                Text="暂无查询结果" />
                                                            <TextBlock Margin="0,8,0,0" Text="执行当前 SQL 后，这里会显示数据行或命令反馈。" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </TabItem>
                                        <TabItem>
                                            <TabItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon
                                                        Width="16"
                                                        Height="16"
                                                        Margin="0,0,6,0"
                                                        Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}"
                                                        Symbol="Pin24" />
                                                    <TextBlock Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}" Text="索引" />
                                                </StackPanel>
                                            </TabItem.Header>
                                            <Border
                                                Margin="0,12,0,0"
                                                Padding="14"
                                                Style="{StaticResource WorkspaceContentCardStyle}">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemsSource="{Binding Schema.Indexes}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border
                                                                    Margin="0,0,0,10"
                                                                    Padding="12"
                                                                    Style="{StaticResource WorkspaceContentCardStyle}">
                                                                    <StackPanel>
                                                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                                        <TextBlock
                                                                            Margin="0,6,0,0"
                                                                            Text="{Binding Sql}"
                                                                            TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Border>
                                        </TabItem>
                                        <TabItem>
                                            <TabItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon
                                                        Width="16"
                                                        Height="16"
                                                        Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}"
                                                        Symbol="Flash24" />
                                                    <TextBlock Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}" Text="触发器" />
                                                </StackPanel>
                                            </TabItem.Header>
                                            <Border
                                                Margin="0,12,0,0"
                                                Padding="14"
                                                Style="{StaticResource WorkspaceContentCardStyle}">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemsSource="{Binding Schema.Triggers}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border
                                                                    Margin="0,0,0,10"
                                                                    Padding="12"
                                                                    Style="{StaticResource WorkspaceContentCardStyle}">
                                                                    <StackPanel>
                                                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                                        <TextBlock
                                                                            Margin="0,6,0,0"
                                                                            Text="{Binding Sql}"
                                                                            TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Border>
                                        </TabItem>
                                        <TabItem>
                                            <TabItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon
                                                        Width="16"
                                                        Height="16"
                                                        Margin="0,0,6,0"
                                                        Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}"
                                                        Symbol="Document24" />
                                                    <TextBlock Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=Foreground}" Text="DDL" />
                                                </StackPanel>
                                            </TabItem.Header>
                                            <Border
                                                Margin="0,12,0,0"
                                                Padding="14"
                                                Style="{StaticResource WorkspaceContentCardStyle}">
                                                <TextBox
                                                    Padding="10"
                                                    AcceptsReturn="True"
                                                    Background="{DynamicResource ControlFillColorInputActiveBrush}"
                                                    BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                                                    BorderThickness="1"
                                                    CaretBrush="{DynamicResource AccentFillColorDefaultBrush}"
                                                    FontFamily="Consolas"
                                                    FontSize="13"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    HorizontalScrollBarVisibility="Auto"
                                                    IsReadOnly="True"
                                                    Text="{Binding Schema.CreateSql}"
                                                    TextWrapping="NoWrap"
                                                    VerticalScrollBarVisibility="Auto" />
                                            </Border>
                                        </TabItem>
                                    </TabControl>
                                </Grid>
                                <StackPanel
                                    Grid.Row="2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    d:Visibility="Hidden"
                                    Style="{StaticResource HideWhenTableSelectedStyle}">
                                    <Border Style="{StaticResource WorkspaceIconTileStyle}">
                                        <ui:SymbolIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                            Symbol="Database24" />
                                    </Border>
                                    <TextBlock
                                        Margin="0,14,0,0"
                                        FontSize="20"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                        Text="请先选择一个表" />
                                    <TextBlock
                                        Margin="0,8,0,0"
                                        Style="{StaticResource WorkspaceMutedTextStyle}"
                                        Text="左侧会列出当前数据库中的全部对象。" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border
                        Grid.Row="4"
                        Padding="10,8"
                        Style="{StaticResource WorkspacePanelStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    d:Text="就绪"
                                    Style="{StaticResource WorkspaceCaptionStyle}"
                                    Text="{Binding FooterStatusText}" />
                                <TextBlock
                                    Margin="18,0,0,0"
                                    d:Text="SQLite"
                                    Style="{StaticResource WorkspaceMutedTextStyle}"
                                    Text="{Binding FooterEngineText}" />
                                <TextBlock
                                    Margin="18,0,0,0"
                                    d:Text="只读"
                                    Style="{StaticResource WorkspaceMutedTextStyle}"
                                    Text="{Binding FooterAccessModeText}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock
                                    d:Text="行: 1,234"
                                    Style="{StaticResource WorkspaceMutedTextStyle}"
                                    Text="{Binding FooterRowCountText}" />
                                <TextBlock
                                    Margin="18,0,0,0"
                                    d:Text="列: 5"
                                    Style="{StaticResource WorkspaceMutedTextStyle}"
                                    Text="{Binding FooterColumnCountText}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border
            Margin="24"
            Padding="32"
            d:Visibility="Hidden"
            BorderThickness="1"
            CornerRadius="24">
            <Border.Style>
                <Style BasedOn="{StaticResource WorkspaceSurfaceStyle}" TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasOpenDatabase}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border
                    Width="52"
                    Height="52"
                    HorizontalAlignment="Center"
                    Style="{StaticResource WorkspaceIconTileStyle}">
                    <ui:SymbolIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                        Symbol="Database24" />
                </Border>
                <TextBlock
                    Margin="0,16,0,0"
                    HorizontalAlignment="Center"
                    d:Text="尚未打开数据库"
                    Style="{StaticResource WorkspacePageTitleStyle}"
                    Text="{Binding EmptyStateTitle}" />
                <TextBlock
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    d:Text="从左侧导航或首页动作中打开一个 SQLite 数据库。"
                    Style="{StaticResource WorkspaceMutedTextStyle}"
                    Text="{Binding EmptyStateDescription}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
