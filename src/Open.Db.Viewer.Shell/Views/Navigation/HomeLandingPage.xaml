<UserControl x:Class="Open.Db.Viewer.Shell.Views.Navigation.HomeLandingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:shell="clr-namespace:Open.Db.Viewer.Shell.ViewModels.Shell"
             mc:Ignorable="d">
    <UserControl.Resources>
        <SolidColorBrush x:Key="LandingPageBackgroundBrush" Color="#F7F3EE" />
        <SolidColorBrush x:Key="LandingCardBrush" Color="#FFFCF8" />
        <SolidColorBrush x:Key="LandingCardBorderBrush" Color="#E6DDD3" />
        <SolidColorBrush x:Key="LandingSubtleBrush" Color="#736C64" />
        <SolidColorBrush x:Key="LandingAccentBrush" Color="#1567D8" />
        <SolidColorBrush x:Key="LandingAccentSoftBrush" Color="#E9F1FF" />
        <SolidColorBrush x:Key="LandingAccentLineBrush" Color="#B8CEF2" />
        <SolidColorBrush x:Key="LandingPanelBrush" Color="#FBF8F4" />
        <SolidColorBrush x:Key="LandingPanelAltBrush" Color="#F4EFE8" />
        <SolidColorBrush x:Key="LandingShadowBrush" Color="#E8DCCF" />

        <DropShadowEffect x:Key="LandingCardShadowEffect"
                          BlurRadius="26"
                          Color="#E7DDD5"
                          Opacity="0.35"
                          ShadowDepth="0" />

        <Style x:Key="SurfaceCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource LandingCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LandingCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Effect" Value="{StaticResource LandingCardShadowEffect}" />
        </Style>

        <Style x:Key="SectionTitleButtonStyle"
               TargetType="ui:Button"
               BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Appearance" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource LandingAccentBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style x:Key="ActionChipButtonStyle"
               TargetType="ui:Button"
               BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderBrush" Value="{StaticResource LandingCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Appearance" Value="Secondary" />
        </Style>

        <Style x:Key="SummaryItemCardStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="{StaticResource LandingCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource LandingCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource LandingPageBackgroundBrush}">
        <Grid Margin="20,18,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Padding="34,34,34,30"
                    Style="{StaticResource SurfaceCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="480" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="20,10,24,0">
                        <TextBlock FontSize="32"
                                   FontWeight="SemiBold"
                                   Foreground="#262626"
                                   LineHeight="58"
                                   Text="更快打开数据库，&#x0a;更专注查看数据" />

                        <StackPanel Margin="0,28,0,0"
                                    Orientation="Horizontal">
                            <ui:Button Width="188"
                                       Height="56"
                                       Appearance="Primary"
                                       Command="{Binding OpenDatabaseCommand}"
                                       Content="打开数据库"
                                       CornerRadius="16"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Icon="{ui:SymbolIcon Database24}" />
                            <ui:Button Width="176"
                                       Height="56"
                                       Margin="16,0,0,0"
                                       Command="{Binding OpenQuickOpenCommand}"
                                       Content="快速打开"
                                       CornerRadius="16"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Icon="{ui:SymbolIcon Flash24}" />
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <Ellipse Width="286"
                                 Height="286"
                                 Margin="50,-6,0,0"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Top"
                                 Fill="#F3EEE8" />

                            <UniformGrid Rows="4"
                                         Columns="4"
                                         Width="70"
                                         Height="70"
                                         Margin="0,20,32,0"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Top">
                                <Ellipse Width="5" Height="5" Fill="#DFD8D1" />
                                <Ellipse Width="5" Height="5" Fill="#DFD8D1" />
                                <Ellipse Width="5" Height="5" Fill="#DFD8D1" />
                                <Ellipse Width="5" Height="5" Fill="#DFD8D1" />
                                <Ellipse Width="5" Height="5" Fill="#DFD8D1" />
                                <Ellipse Width="5" Height="5" Fill="#DFD8D1" />
                                <Ellipse Width="5" Height="5" Fill="#DFD8D1" />
                                <Ellipse Width="5" Height="5" Fill="#DFD8D1" />
                                <Ellipse Width="5" Height="5" Fill="#DFD8D1" />
                                <Ellipse Width="5" Height="5" Fill="#DFD8D1" />
                                <Ellipse Width="5" Height="5" Fill="#DFD8D1" />
                                <Ellipse Width="5" Height="5" Fill="#DFD8D1" />
                                <Ellipse Width="5" Height="5" Fill="#DFD8D1" />
                                <Ellipse Width="5" Height="5" Fill="#DFD8D1" />
                                <Ellipse Width="5" Height="5" Fill="#DFD8D1" />
                                <Ellipse Width="5" Height="5" Fill="#DFD8D1" />
                            </UniformGrid>

                            <Border Width="238"
                                    Height="182"
                                    Margin="0,52,84,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Background="#FFFDFB"
                                    BorderBrush="{StaticResource LandingAccentLineBrush}"
                                    BorderThickness="1.4"
                                    CornerRadius="18">
                                <Grid Margin="18">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="18" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="26"
                                                Height="26"
                                                CornerRadius="7"
                                                BorderBrush="{StaticResource LandingAccentLineBrush}"
                                                BorderThickness="1.2">
                                            <ui:SymbolIcon HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="#7E9CCB"
                                                           Symbol="Document24" />
                                        </Border>
                                        <StackPanel Margin="14,4,0,0">
                                            <Border Width="92"
                                                    Height="5"
                                                    Background="#D4E1F7"
                                                    CornerRadius="3" />
                                            <Border Width="74"
                                                    Height="5"
                                                    Margin="0,8,0,0"
                                                    Background="#DDE7F8"
                                                    CornerRadius="3" />
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Grid.Row="2"
                                            Height="5"
                                            Background="#D6E1F4"
                                            CornerRadius="3" />
                                    <Border Grid.Row="4"
                                            Width="164"
                                            Height="5"
                                            HorizontalAlignment="Left"
                                            Background="#D6E1F4"
                                            CornerRadius="3" />
                                    <Border Grid.Row="6"
                                            Width="154"
                                            Height="5"
                                            HorizontalAlignment="Left"
                                            Background="#D6E1F4"
                                            CornerRadius="3" />
                                    <Border Grid.Row="8"
                                            Width="132"
                                            Height="5"
                                            HorizontalAlignment="Left"
                                            Background="#D6E1F4"
                                            CornerRadius="3" />
                                    <Border Grid.Row="10"
                                            Width="98"
                                            Height="5"
                                            HorizontalAlignment="Left"
                                            Background="#D6E1F4"
                                            CornerRadius="3" />
                                </Grid>
                            </Border>

                            <Grid Width="112"
                                  Height="136"
                                  Margin="0,0,26,26"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Bottom">
                                <Ellipse Width="112"
                                         Height="28"
                                         VerticalAlignment="Top"
                                         Fill="#E4EAF5"
                                         Stroke="#D4DCEA"
                                         StrokeThickness="1" />
                                <Border Width="110"
                                        Height="74"
                                        Margin="1,14,1,0"
                                        VerticalAlignment="Top">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0"
                                                             EndPoint="1,0">
                                            <GradientStop Offset="0" Color="#F4F7FD" />
                                            <GradientStop Offset="0.5" Color="#C8D4E9" />
                                            <GradientStop Offset="1" Color="#F5F8FD" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Ellipse Width="112"
                                         Height="28"
                                         Margin="0,34,0,0"
                                         VerticalAlignment="Top"
                                         Fill="#DEE6F3"
                                         Stroke="#CED9E8"
                                         StrokeThickness="1" />
                                <Ellipse Width="112"
                                         Height="28"
                                         Margin="0,68,0,0"
                                         VerticalAlignment="Top"
                                         Fill="#E7EDF7"
                                         Stroke="#D6DFEB"
                                         StrokeThickness="1" />
                            </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Padding="20"
                    Style="{StaticResource SurfaceCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Margin="0,2,10,0"
                                               Foreground="#303030"
                                               Symbol="Flash24" />
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="快速打开" />
                            </StackPanel>

                            <ui:Button Grid.Column="1"
                                       Style="{StaticResource SectionTitleButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontSize="15"
                                               FontWeight="SemiBold"
                                               Text="查看全部" />
                                    <ui:SymbolIcon Margin="6,2,0,0"
                                                   Foreground="{StaticResource LandingAccentBrush}"
                                                   Symbol="ChevronRight24" />
                                </StackPanel>
                                <ui:Button.Command>
                                    <Binding Path="DataContext.NavigateToSectionCommand"
                                             RelativeSource="{RelativeSource AncestorType=Window}" />
                                </ui:Button.Command>
                                <ui:Button.CommandParameter>
                                    <x:Static Member="shell:ShellSection.Recent" />
                                </ui:Button.CommandParameter>
                            </ui:Button>
                        </Grid>

                        <Border Grid.Row="2"
                                Padding="14"
                                Background="{StaticResource LandingPanelBrush}"
                                BorderBrush="{StaticResource LandingCardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Width="56"
                                        Height="56"
                                        Background="{StaticResource LandingAccentSoftBrush}"
                                        CornerRadius="28">
                                    <ui:SymbolIcon HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource LandingAccentBrush}"
                                                   Symbol="Database24" />
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Margin="16,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock FontSize="17"
                                               FontWeight="SemiBold"
                                               Text="{Binding QuickOpenEntry.Name, FallbackValue=app, TargetNullValue=app}" />
                                    <TextBlock Margin="0,5,0,0"
                                               Foreground="{StaticResource LandingSubtleBrush}"
                                               Text="{Binding QuickOpenEntry.FilePath, TargetNullValue=C:\Users\Administrator\AppData\Local\Vision.Aoi.Studio\config\app.db}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <ui:Button Grid.Column="2"
                                           Width="98"
                                           Height="42"
                                           Margin="16,0,12,0"
                                           VerticalAlignment="Center"
                                           Command="{Binding OpenQuickOpenCommand}"
                                           Content="打开"
                                           CornerRadius="14"
                                           FontWeight="SemiBold" />

                                <ui:Button Grid.Column="3"
                                           VerticalAlignment="Center"
                                           Command="{Binding OpenEntryCommand}"
                                           CommandParameter="{Binding QuickOpenEntry}"
                                           Style="{StaticResource ActionChipButtonStyle}"
                                           ToolTip="打开此数据库">
                                    <ui:SymbolIcon Foreground="{StaticResource LandingSubtleBrush}"
                                                   Symbol="MoreVertical24" />
                                </ui:Button>
                            </Grid>
                        </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                    <Border Padding="20"
                            Style="{StaticResource SurfaceCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Margin="0,2,10,0"
                                                   Foreground="#303030"
                                                   Symbol="Pin24" />
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="已固定的数据库" />
                                </StackPanel>

                                <ui:Button Grid.Column="1"
                                           Style="{StaticResource SectionTitleButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Text="查看全部" />
                                        <ui:SymbolIcon Margin="6,2,0,0"
                                                       Foreground="{StaticResource LandingAccentBrush}"
                                                       Symbol="ChevronRight24" />
                                    </StackPanel>
                                    <ui:Button.Command>
                                        <Binding Path="DataContext.NavigateToSectionCommand"
                                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                                    </ui:Button.Command>
                                    <ui:Button.CommandParameter>
                                        <x:Static Member="shell:ShellSection.Pinned" />
                                    </ui:Button.CommandParameter>
                                </ui:Button>
                            </Grid>

                            <ItemsControl Grid.Row="2"
                                          ItemsSource="{Binding PinnedSummary}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource SummaryItemCardStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="54"
                                                        Height="54"
                                                        Background="{StaticResource LandingAccentSoftBrush}"
                                                        CornerRadius="27">
                                                    <ui:SymbolIcon HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{StaticResource LandingAccentBrush}"
                                                                   Symbol="Database24" />
                                                </Border>

                                                <StackPanel Grid.Column="1"
                                                            Margin="14,0,0,0"
                                                            VerticalAlignment="Center">
                                                    <TextBlock FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding Name}" />
                                                    <TextBlock Margin="0,5,0,0"
                                                               Foreground="{StaticResource LandingSubtleBrush}"
                                                               Text="{Binding FilePath}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>

                                                <ui:Button Grid.Column="2"
                                                           Margin="12,0,10,0"
                                                           VerticalAlignment="Center"
                                                           Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                           CommandParameter="{Binding}"
                                                           Style="{StaticResource ActionChipButtonStyle}"
                                                           ToolTip="取消固定">
                                                    <ui:SymbolIcon Foreground="{StaticResource LandingSubtleBrush}"
                                                                   Symbol="Pin24" />
                                                </ui:Button>

                                                <ui:Button Grid.Column="3"
                                                           VerticalAlignment="Center"
                                                           Command="{Binding DataContext.OpenEntryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                           CommandParameter="{Binding}"
                                                           Style="{StaticResource ActionChipButtonStyle}"
                                                           ToolTip="打开此数据库">
                                                    <ui:SymbolIcon Foreground="{StaticResource LandingSubtleBrush}"
                                                                   Symbol="MoreVertical24" />
                                                </ui:Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="20"
                            Style="{StaticResource SurfaceCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Margin="0,2,10,0"
                                                   Foreground="#303030"
                                                   Symbol="History24" />
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="最近使用" />
                                </StackPanel>

                                <ui:Button Grid.Column="1"
                                           Style="{StaticResource SectionTitleButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Text="查看全部" />
                                        <ui:SymbolIcon Margin="6,2,0,0"
                                                       Foreground="{StaticResource LandingAccentBrush}"
                                                       Symbol="ChevronRight24" />
                                    </StackPanel>
                                    <ui:Button.Command>
                                        <Binding Path="DataContext.NavigateToSectionCommand"
                                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                                    </ui:Button.Command>
                                    <ui:Button.CommandParameter>
                                        <x:Static Member="shell:ShellSection.Recent" />
                                    </ui:Button.CommandParameter>
                                </ui:Button>
                            </Grid>

                            <ItemsControl Grid.Row="2"
                                          ItemsSource="{Binding RecentSummary}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource SummaryItemCardStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="54"
                                                        Height="54"
                                                        Background="{StaticResource LandingAccentSoftBrush}"
                                                        CornerRadius="27">
                                                    <ui:SymbolIcon HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{StaticResource LandingAccentBrush}"
                                                                   Symbol="Database24" />
                                                </Border>

                                                <StackPanel Grid.Column="1"
                                                            Margin="14,0,0,0"
                                                            VerticalAlignment="Center">
                                                    <TextBlock FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding Name}" />
                                                    <TextBlock Margin="0,5,0,0"
                                                               Foreground="{StaticResource LandingSubtleBrush}"
                                                               Text="{Binding FilePath}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>

                                                <ui:Button Grid.Column="2"
                                                           Margin="12,0,10,0"
                                                           VerticalAlignment="Center"
                                                           Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                           CommandParameter="{Binding}"
                                                           Style="{StaticResource ActionChipButtonStyle}"
                                                           ToolTip="固定或取消固定">
                                                    <ui:SymbolIcon Foreground="{StaticResource LandingSubtleBrush}"
                                                                   Symbol="Pin24" />
                                                </ui:Button>

                                                <ui:Button Grid.Column="3"
                                                           VerticalAlignment="Center"
                                                           Command="{Binding DataContext.OpenEntryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                           CommandParameter="{Binding}"
                                                           Style="{StaticResource ActionChipButtonStyle}"
                                                           ToolTip="打开此数据库">
                                                    <ui:SymbolIcon Foreground="{StaticResource LandingSubtleBrush}"
                                                                   Symbol="MoreVertical24" />
                                                </ui:Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
