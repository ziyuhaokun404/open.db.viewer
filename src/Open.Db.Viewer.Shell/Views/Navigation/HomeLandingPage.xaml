<UserControl x:Class="Open.Db.Viewer.Shell.Views.Navigation.HomeLandingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:shell="clr-namespace:Open.Db.Viewer.Shell.ViewModels.Shell"
             mc:Ignorable="d">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PageCardBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PageCardBorderBrush" Color="#DCE5F1" />
        <SolidColorBrush x:Key="PageMutedBrush" Color="#6D7890" />
        <SolidColorBrush x:Key="PageAccentBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="PageAccentSoftBrush" Color="#E8F1FF" />
        <SolidColorBrush x:Key="PageAccentLineBrush" Color="#BED4FF" />
        <SolidColorBrush x:Key="PageShellBrush" Color="#F8FBFF" />
        <SolidColorBrush x:Key="PageShadowBrush" Color="#EEF4FE" />

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PageCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PageCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="26" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <Style x:Key="InlineLinkButtonStyle"
               TargetType="ui:Button"
               BasedOn="{StaticResource {x:Type ui:Button}}">
            <Setter Property="Appearance" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource PageAccentBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="18,18,18,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="470" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,2,24,0">
                    <Border Width="78"
                            Padding="10,5"
                            HorizontalAlignment="Left"
                            Background="{StaticResource PageAccentSoftBrush}"
                            BorderBrush="{StaticResource PageAccentLineBrush}"
                            BorderThickness="1"
                            CornerRadius="999">
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PageAccentBrush}"
                                   Text="HOME" />
                    </Border>

                    <TextBlock Margin="0,18,0,0"
                               FontSize="34"
                               FontWeight="SemiBold"
                               Text="更快打开数据库，&#x0a;更专注查看数据" />
                    <TextBlock Margin="0,14,0,0"
                               Foreground="{StaticResource PageMutedBrush}"
                               FontSize="14"
                               LineHeight="20"
                               Text="浏览 SQLite 文件、查看表结构、快速运行 SQL，&#x0a;并把常用数据库固定在首页，像工作台一样持续使用" />

                    <StackPanel Margin="0,24,0,0"
                                Orientation="Horizontal">
                        <ui:Button Width="170"
                                   Height="48"
                                   Appearance="Primary"
                                   Command="{Binding OpenDatabaseCommand}"
                                   Content="打开数据库"
                                   CornerRadius="16"
                                   Icon="{ui:SymbolIcon Database24}" />
                        <ui:Button Width="164"
                                   Height="48"
                                   Margin="14,0,0,0"
                                   Command="{Binding OpenQuickOpenCommand}"
                                   Content="快速打开"
                                   CornerRadius="16"
                                   Icon="{ui:SymbolIcon Flash24}" />
                    </StackPanel>

                    <Border Margin="0,26,0,0"
                            Padding="14,12"
                            Background="{StaticResource PageShellBrush}"
                            BorderBrush="{StaticResource PageCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Width="28"
                                    Height="28"
                                    Background="{StaticResource PageAccentSoftBrush}"
                                    CornerRadius="14">
                                <ui:SymbolIcon HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource PageAccentBrush}"
                                               Symbol="Info24" />
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource PageMutedBrush}"
                                       FontSize="13"
                                       Text="小贴士：拖放 SQLite 文件到窗口可快速打开" />
                        </Grid>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="1"
                      Margin="8,0,0,0">
                    <Border CornerRadius="28">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,1">
                                <GradientStop Offset="0"
                                              Color="#F6FAFF" />
                                <GradientStop Offset="1"
                                              Color="#EAF2FF" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <Ellipse Width="276"
                             Height="276"
                             Margin="28,-18,0,0"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             Fill="#ECF3FF" />
                    <Ellipse Width="232"
                             Height="232"
                             Margin="0,0,-26,-6"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Bottom"
                             Fill="#E4EEFF" />

                    <UniformGrid Rows="4"
                                 Columns="4"
                                 Width="64"
                                 Height="64"
                                 Margin="0,10,26,0"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top">
                        <Ellipse Width="4" Height="4" Fill="#C9DCFF" />
                        <Ellipse Width="4" Height="4" Fill="#C9DCFF" />
                        <Ellipse Width="4" Height="4" Fill="#C9DCFF" />
                        <Ellipse Width="4" Height="4" Fill="#C9DCFF" />
                        <Ellipse Width="4" Height="4" Fill="#C9DCFF" />
                        <Ellipse Width="4" Height="4" Fill="#C9DCFF" />
                        <Ellipse Width="4" Height="4" Fill="#C9DCFF" />
                        <Ellipse Width="4" Height="4" Fill="#C9DCFF" />
                        <Ellipse Width="4" Height="4" Fill="#C9DCFF" />
                        <Ellipse Width="4" Height="4" Fill="#C9DCFF" />
                        <Ellipse Width="4" Height="4" Fill="#C9DCFF" />
                        <Ellipse Width="4" Height="4" Fill="#C9DCFF" />
                        <Ellipse Width="4" Height="4" Fill="#C9DCFF" />
                        <Ellipse Width="4" Height="4" Fill="#C9DCFF" />
                        <Ellipse Width="4" Height="4" Fill="#C9DCFF" />
                        <Ellipse Width="4" Height="4" Fill="#C9DCFF" />
                    </UniformGrid>

                    <Border Width="320"
                            Height="270"
                            Margin="0,30,56,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="#F2F7FF"
                            BorderBrush="#E0EBFF"
                            BorderThickness="1"
                            CornerRadius="28" />

                    <Border Width="88"
                            Padding="14,12"
                            Margin="116,44,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#FFFFFF"
                            BorderBrush="#D8E5FA"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel>
                            <TextBlock FontSize="11"
                                       Foreground="{StaticResource PageMutedBrush}"
                                       Text="固定数据库" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Text="{Binding PinnedSummary.Count}" />
                        </StackPanel>
                    </Border>

                    <Border Width="250"
                            Height="206"
                            Margin="0,52,72,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="#FFFFFF"
                            BorderBrush="#D7E5FC"
                            BorderThickness="1"
                            CornerRadius="24">
                        <Grid Margin="18">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Ellipse Width="12"
                                     Height="12"
                                     HorizontalAlignment="Left"
                                     Fill="#42D392" />
                            <Border Grid.Row="2"
                                    Padding="14"
                                    Background="#F6FAFF"
                                    BorderBrush="#E0EBFF"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               FontWeight="SemiBold"
                                               Text="chinook.db" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource PageMutedBrush}"
                                               Text="SQLite" />
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Row="4">
                                <Border Height="12"
                                        Margin="0,0,0,10"
                                        Background="#DDEAFF"
                                        CornerRadius="6" />
                                <Border Width="144"
                                        Height="12"
                                        Margin="0,0,0,10"
                                        HorizontalAlignment="Left"
                                        Background="#DFEBFF"
                                        CornerRadius="6" />
                                <Border Width="110"
                                        Height="12"
                                        Margin="0,0,0,10"
                                        HorizontalAlignment="Left"
                                        Background="#DFEBFF"
                                        CornerRadius="6" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Width="114"
                          Height="140"
                          Margin="0,0,22,54"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom">
                        <Ellipse Width="114"
                                 Height="30"
                                 VerticalAlignment="Top"
                                 Fill="#BBD2FF"
                                 Stroke="#8CB2FF"
                                 StrokeThickness="1" />
                        <Border Width="112"
                                Height="84"
                                Margin="1,15,1,0"
                                VerticalAlignment="Top">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0"
                                                     EndPoint="1,0">
                                    <GradientStop Offset="0" Color="#CFE0FF" />
                                    <GradientStop Offset="0.55" Color="#8BB0FF" />
                                    <GradientStop Offset="1" Color="#6F99F8" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Ellipse Width="114"
                                 Height="30"
                                 Margin="0,54,0,0"
                                 VerticalAlignment="Top"
                                 Fill="#9DC0FF"
                                 Stroke="#7BA5FF"
                                 StrokeThickness="1" />
                        <Ellipse Width="114"
                                 Height="30"
                                 Margin="0,88,0,0"
                                 VerticalAlignment="Top"
                                 Fill="#87AEFF"
                                 Stroke="#6E9AF8"
                                 StrokeThickness="1" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource SectionCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Margin="0,2,10,0"
                                       Foreground="{StaticResource PageAccentBrush}"
                                       Symbol="Flash24" />
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Text="快速打开" />
                        <TextBlock Margin="12,7,0,0"
                                   Foreground="{StaticResource PageMutedBrush}"
                                   FontSize="12"
                                   Text="直接回到最近一次使用的数据库，继续你的上一次工作。" />
                    </StackPanel>

                    <ui:Button Grid.Column="1"
                               VerticalAlignment="Top"
                               Style="{StaticResource InlineLinkButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontWeight="SemiBold"
                                       Text="查看全部" />
                            <ui:SymbolIcon Margin="6,2,0,0"
                                           Foreground="{StaticResource PageAccentBrush}"
                                           Symbol="ArrowRight24" />
                        </StackPanel>
                        <ui:Button.Command>
                            <Binding Path="DataContext.NavigateToSectionCommand"
                                     RelativeSource="{RelativeSource AncestorType=Window}" />
                        </ui:Button.Command>
                        <ui:Button.CommandParameter>
                            <x:Static Member="shell:ShellSection.Recent" />
                        </ui:Button.CommandParameter>
                    </ui:Button>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.15*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.25*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="14"
                            Background="{StaticResource PageShellBrush}"
                            BorderBrush="{StaticResource PageCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Width="52"
                                    Height="52"
                                    Background="#DCEAFF"
                                    CornerRadius="26">
                                <ui:SymbolIcon HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource PageAccentBrush}"
                                               Symbol="Clock24" />
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Margin="14,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock FontSize="17"
                                           FontWeight="SemiBold"
                                           Text="{Binding QuickOpenEntry.Name, FallbackValue=app, TargetNullValue=尚未打开数据库}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource PageMutedBrush}"
                                           Text="{Binding QuickOpenEntry.FilePath, FallbackValue=从左侧开始打开第一个 SQLite 文件, TargetNullValue=从左侧开始打开第一个 SQLite 文件}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <ui:Button Grid.Column="2"
                                       Width="120"
                                       Height="42"
                                       VerticalAlignment="Center"
                                       Command="{Binding OpenQuickOpenCommand}"
                                       Content="立即打开"
                                       CornerRadius="14" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="14"
                            Background="{StaticResource PageShellBrush}"
                            BorderBrush="{StaticResource PageCardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="12"
                                           Foreground="{StaticResource PageMutedBrush}"
                                           Text="最近" />
                                <TextBlock Margin="0,6,0,0"
                                           FontWeight="SemiBold"
                                           Text="{Binding QuickOpenEntry.Name, FallbackValue=app, TargetNullValue=尚未打开数据库}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{StaticResource PageMutedBrush}"
                                           Text="{Binding QuickOpenEntry.FilePath, FallbackValue=从左侧开始打开第一个 SQLite 文件, TargetNullValue=从左侧开始打开第一个 SQLite 文件}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>

                            <ui:SymbolIcon Grid.Column="1"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource PageMutedBrush}"
                                           Symbol="MoreHorizontal24" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Margin="0,2,10,0"
                                           Foreground="{StaticResource PageAccentBrush}"
                                           Symbol="Pin24" />
                            <TextBlock FontSize="22"
                                       FontWeight="SemiBold"
                                       Text="已固定的数据库" />
                        </StackPanel>

                        <ui:Button Grid.Column="1"
                                   VerticalAlignment="Top"
                                   Style="{StaticResource InlineLinkButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="SemiBold"
                                           Text="查看全部" />
                                <ui:SymbolIcon Margin="6,2,0,0"
                                               Foreground="{StaticResource PageAccentBrush}"
                                               Symbol="ArrowRight24" />
                            </StackPanel>
                            <ui:Button.Command>
                                <Binding Path="DataContext.NavigateToSectionCommand"
                                         RelativeSource="{RelativeSource AncestorType=Window}" />
                            </ui:Button.Command>
                            <ui:Button.CommandParameter>
                                <x:Static Member="shell:ShellSection.Pinned" />
                            </ui:Button.CommandParameter>
                        </ui:Button>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Foreground="{StaticResource PageMutedBrush}"
                               Text="把高频数据库放在这里，减少每次重新定位文件的成本。" />

                    <ItemsControl Grid.Row="2"
                                  ItemsSource="{Binding PinnedSummary}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="14"
                                        Background="{StaticResource PageShellBrush}"
                                        BorderBrush="{StaticResource PageCardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="44"
                                                Height="44"
                                                Background="#DCEAFF"
                                                CornerRadius="22">
                                            <ui:SymbolIcon HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource PageAccentBrush}"
                                                           Symbol="Database24" />
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Margin="14,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Name}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{StaticResource PageMutedBrush}"
                                                       Text="{Binding FilePath}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <ui:SymbolIcon Grid.Column="2"
                                                       Margin="12,0,10,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource PageMutedBrush}"
                                                       Symbol="Pin24" />
                                        <ui:SymbolIcon Grid.Column="3"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource PageMutedBrush}"
                                                       Symbol="MoreHorizontal24" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource SectionCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Margin="0,2,10,0"
                                           Foreground="{StaticResource PageAccentBrush}"
                                           Symbol="Clock24" />
                            <TextBlock FontSize="22"
                                       FontWeight="SemiBold"
                                       Text="最近使用" />
                        </StackPanel>

                        <ui:Button Grid.Column="1"
                                   VerticalAlignment="Top"
                                   Style="{StaticResource InlineLinkButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontWeight="SemiBold"
                                           Text="查看全部" />
                                <ui:SymbolIcon Margin="6,2,0,0"
                                               Foreground="{StaticResource PageAccentBrush}"
                                               Symbol="ArrowRight24" />
                            </StackPanel>
                            <ui:Button.Command>
                                <Binding Path="DataContext.NavigateToSectionCommand"
                                         RelativeSource="{RelativeSource AncestorType=Window}" />
                            </ui:Button.Command>
                            <ui:Button.CommandParameter>
                                <x:Static Member="shell:ShellSection.Recent" />
                            </ui:Button.CommandParameter>
                        </ui:Button>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Foreground="{StaticResource PageMutedBrush}"
                               Text="保留最近访问记录，随时返回上一次查看的位置。" />

                    <ItemsControl Grid.Row="2"
                                  ItemsSource="{Binding RecentSummary}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="14"
                                        Background="{StaticResource PageShellBrush}"
                                        BorderBrush="{StaticResource PageCardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="44"
                                                Height="44"
                                                Background="#DCEAFF"
                                                CornerRadius="22">
                                            <ui:SymbolIcon HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource PageAccentBrush}"
                                                           Symbol="Clock24" />
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Margin="14,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Name}" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{StaticResource PageMutedBrush}"
                                                       Text="{Binding FilePath}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="{StaticResource PageMutedBrush}"
                                                       FontSize="12"
                                                       Text="今天 14:32" />
                                        </StackPanel>
                                        <ui:SymbolIcon Grid.Column="2"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource PageMutedBrush}"
                                                       Symbol="MoreHorizontal24" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
