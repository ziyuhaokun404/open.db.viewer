<UserControl
    x:Class="Open.Db.Viewer.Shell.Views.Navigation.HomeLandingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="clr-namespace:Open.Db.Viewer.Shell.ViewModels.Shell"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:Height="820"
    d:Width="1180"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="DashboardPanelStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="{DynamicResource LandingDashboardPanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LandingDashboardPanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style
            x:Key="DashboardHeroPanelStyle"
            BasedOn="{StaticResource DashboardPanelStyle}"
            TargetType="Border">
            <Setter Property="Padding" Value="28,22" />
            <Setter Property="Background" Value="{DynamicResource LandingDashboardHeroBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LandingDashboardPanelBorderStrongBrush}" />
        </Style>

        <Style
            x:Key="DashboardSidePanelStyle"
            BasedOn="{StaticResource DashboardPanelStyle}"
            TargetType="Border">
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="DashboardListItemStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Background" Value="{DynamicResource LandingDashboardListItemBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LandingDashboardPanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style x:Key="DashboardPrimaryTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource LandingDashboardPrimaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="DashboardSecondaryTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="LineHeight" Value="17" />
            <Setter Property="Foreground" Value="{DynamicResource LandingDashboardSecondaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="DashboardMutedTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="LineHeight" Value="16" />
            <Setter Property="Foreground" Value="{DynamicResource LandingDashboardMutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="DashboardSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource LandingDashboardPrimaryTextBrush}" />
        </Style>

        <Style x:Key="DashboardBadgeStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="{DynamicResource LandingDashboardBadgeBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LandingDashboardBadgeBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>

        <Style x:Key="DashboardIconShellStyle" TargetType="Border">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="{DynamicResource LandingDashboardIconShellBrush}" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>

        <Style
            x:Key="DashboardActionButtonStyle"
            BasedOn="{StaticResource {x:Type ui:Button}}"
            TargetType="ui:Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style
            x:Key="DashboardIconButtonStyle"
            BasedOn="{StaticResource {x:Type ui:Button}}"
            TargetType="ui:Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Appearance" Value="Secondary" />
            <Setter Property="BorderBrush" Value="{DynamicResource LandingDashboardPanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style
            x:Key="DashboardLinkButtonStyle"
            BasedOn="{StaticResource {x:Type ui:Button}}"
            TargetType="ui:Button">
            <Setter Property="Appearance" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource LandingDashboardAccentBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource LandingDashboardPageBackgroundBrush}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid
                MaxWidth="1260"
                Margin="16,10,16,18"
                HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Row 0: Hero + side panel  -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="300" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource DashboardHeroPanelStyle}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource DashboardPrimaryTitleStyle}" Text="SQLite 数据工作台" />
                            <TextBlock
                                Margin="0,8,0,0"
                                Style="{StaticResource DashboardSecondaryTextStyle}"
                                Text="轻量打开 SQLite 数据库，快速进入表结构、数据浏览和 SQL 查询工作流。" />

                            <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                                <ui:Button
                                    Width="150"
                                    Appearance="Primary"
                                    Command="{Binding OpenDatabaseCommand}"
                                    Content="打开数据库"
                                    Icon="{ui:SymbolIcon Database24}"
                                    Style="{StaticResource DashboardActionButtonStyle}" />
                                <ui:Button
                                    Width="140"
                                    Margin="10,0,0,0"
                                    Command="{Binding OpenQuickOpenCommand}"
                                    Content="快速打开"
                                    Icon="{ui:SymbolIcon Flash24}"
                                    Style="{StaticResource DashboardActionButtonStyle}" />
                            </StackPanel>

                            <WrapPanel Margin="0,18,0,0">
                                <Border Style="{StaticResource DashboardBadgeStyle}">
                                    <TextBlock Style="{StaticResource DashboardMutedTextStyle}" Text="Schema" />
                                </Border>
                                <Border Style="{StaticResource DashboardBadgeStyle}">
                                    <TextBlock Style="{StaticResource DashboardMutedTextStyle}" Text="Data Grid" />
                                </Border>
                                <Border Style="{StaticResource DashboardBadgeStyle}">
                                    <TextBlock Style="{StaticResource DashboardMutedTextStyle}" Text="Query" />
                                </Border>
                                <Border Style="{StaticResource DashboardBadgeStyle}">
                                    <TextBlock Style="{StaticResource DashboardMutedTextStyle}" Text="Pinned DB" />
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource DashboardSidePanelStyle}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Style="{StaticResource DashboardSectionTitleStyle}" Text="当前入口" />
                                <ui:SymbolIcon
                                    Grid.Column="1"
                                    Foreground="{DynamicResource LandingDashboardAccentBrush}"
                                    Symbol="DataUsage24" />
                            </Grid>

                            <Border
                                Margin="0,14,0,0"
                                Padding="12"
                                Background="{DynamicResource LandingDashboardListItemBrush}"
                                BorderBrush="{DynamicResource LandingDashboardPanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Style="{StaticResource DashboardIconShellStyle}">
                                        <ui:SymbolIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource LandingDashboardAccentBrush}"
                                            Symbol="Database24" />
                                    </Border>
                                    <StackPanel
                                        Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource LandingDashboardPrimaryTextBrush}"
                                            Text="{Binding QuickOpenEntry.Name, FallbackValue=app, TargetNullValue=app}" />
                                        <TextBlock
                                            Margin="0,4,0,0"
                                            Style="{StaticResource DashboardMutedTextStyle}"
                                            Text="{Binding QuickOpenEntry.FilePath, TargetNullValue=等待选择数据库}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Padding="12"
                                    Background="{DynamicResource LandingDashboardListItemBrush}"
                                    BorderBrush="{DynamicResource LandingDashboardPanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource DashboardMutedTextStyle}" Text="最近" />
                                        <TextBlock
                                            Margin="0,4,0,0"
                                            FontSize="22"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource LandingDashboardPrimaryTextBrush}"
                                            Text="{Binding RecentSummary.Count}" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Column="2"
                                    Padding="12"
                                    Background="{DynamicResource LandingDashboardListItemBrush}"
                                    BorderBrush="{DynamicResource LandingDashboardPanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource DashboardMutedTextStyle}" Text="固定" />
                                        <TextBlock
                                            Margin="0,4,0,0"
                                            FontSize="22"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource LandingDashboardPrimaryTextBrush}"
                                            Text="{Binding PinnedSummary.Count}" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <TextBlock
                                Margin="0,14,0,0"
                                Style="{StaticResource DashboardMutedTextStyle}"
                                Text="{Binding StatusMessage}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!--  Row 2: Recent + Pinned panels  -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource DashboardPanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon
                                        Margin="0,1,8,0"
                                        Foreground="{DynamicResource LandingDashboardAccentBrush}"
                                        Symbol="History24" />
                                    <TextBlock Style="{StaticResource DashboardSectionTitleStyle}" Text="最近使用" />
                                </StackPanel>

                                <ui:Button Grid.Column="1" Style="{StaticResource DashboardLinkButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontWeight="SemiBold" Text="查看全部" />
                                        <ui:SymbolIcon
                                            Margin="6,1,0,0"
                                            Foreground="{DynamicResource LandingDashboardAccentBrush}"
                                            Symbol="ChevronRight24" />
                                    </StackPanel>
                                    <ui:Button.Command>
                                        <Binding Path="DataContext.NavigateToSectionCommand" RelativeSource="{RelativeSource AncestorType=Window}" />
                                    </ui:Button.Command>
                                    <ui:Button.CommandParameter>
                                        <x:Static Member="shell:ShellSection.Recent" />
                                    </ui:Button.CommandParameter>
                                </ui:Button>
                            </Grid>

                            <ItemsControl Grid.Row="2" ItemsSource="{Binding RecentSummary}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource DashboardListItemStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Style="{StaticResource DashboardIconShellStyle}">
                                                    <ui:SymbolIcon
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Foreground="{DynamicResource LandingDashboardAccentBrush}"
                                                        Symbol="Database24" />
                                                </Border>

                                                <StackPanel
                                                    Grid.Column="1"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center">
                                                    <TextBlock
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource LandingDashboardPrimaryTextBrush}"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Margin="0,4,0,0"
                                                        Style="{StaticResource DashboardMutedTextStyle}"
                                                        Text="{Binding FilePath}"
                                                        TextTrimming="CharacterEllipsis" />
                                                </StackPanel>

                                                <ui:Button
                                                    Grid.Column="2"
                                                    Margin="10,0,8,0"
                                                    Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DashboardIconButtonStyle}"
                                                    ToolTip="固定或取消固定">
                                                    <ui:SymbolIcon Foreground="{DynamicResource LandingDashboardMutedTextBrush}" Symbol="Pin24" />
                                                </ui:Button>

                                                <ui:Button
                                                    Grid.Column="3"
                                                    Command="{Binding DataContext.OpenEntryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DashboardIconButtonStyle}"
                                                    ToolTip="打开此数据库">
                                                    <ui:SymbolIcon Foreground="{DynamicResource LandingDashboardMutedTextBrush}" Symbol="ArrowEnterLeft24" />
                                                </ui:Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource DashboardPanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon
                                        Margin="0,1,8,0"
                                        Foreground="{DynamicResource LandingDashboardAccentBrush}"
                                        Symbol="Pin24" />
                                    <TextBlock Style="{StaticResource DashboardSectionTitleStyle}" Text="已固定" />
                                </StackPanel>

                                <ui:Button Grid.Column="1" Style="{StaticResource DashboardLinkButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontWeight="SemiBold" Text="查看全部" />
                                        <ui:SymbolIcon
                                            Margin="6,1,0,0"
                                            Foreground="{DynamicResource LandingDashboardAccentBrush}"
                                            Symbol="ChevronRight24" />
                                    </StackPanel>
                                    <ui:Button.Command>
                                        <Binding Path="DataContext.NavigateToSectionCommand" RelativeSource="{RelativeSource AncestorType=Window}" />
                                    </ui:Button.Command>
                                    <ui:Button.CommandParameter>
                                        <x:Static Member="shell:ShellSection.Pinned" />
                                    </ui:Button.CommandParameter>
                                </ui:Button>
                            </Grid>

                            <ItemsControl Grid.Row="2" ItemsSource="{Binding PinnedSummary}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource DashboardListItemStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Style="{StaticResource DashboardIconShellStyle}">
                                                    <ui:SymbolIcon
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Foreground="{DynamicResource LandingDashboardAccentBrush}"
                                                        Symbol="Database24" />
                                                </Border>

                                                <StackPanel
                                                    Grid.Column="1"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center">
                                                    <TextBlock
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource LandingDashboardPrimaryTextBrush}"
                                                        Text="{Binding Name}" />
                                                    <TextBlock
                                                        Margin="0,4,0,0"
                                                        Style="{StaticResource DashboardMutedTextStyle}"
                                                        Text="固定在首页快捷访问"
                                                        TextTrimming="CharacterEllipsis" />
                                                </StackPanel>

                                                <ui:Button
                                                    Grid.Column="2"
                                                    Margin="10,0,8,0"
                                                    Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DashboardIconButtonStyle}"
                                                    ToolTip="取消固定">
                                                    <ui:SymbolIcon Foreground="{DynamicResource LandingDashboardMutedTextBrush}" Symbol="Pin24" />
                                                </ui:Button>

                                                <ui:Button
                                                    Grid.Column="3"
                                                    Command="{Binding DataContext.OpenEntryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DashboardIconButtonStyle}"
                                                    ToolTip="打开此数据库">
                                                    <ui:SymbolIcon Foreground="{DynamicResource LandingDashboardMutedTextBrush}" Symbol="ArrowEnterLeft24" />
                                                </ui:Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>

                <Border
                    Grid.Row="4"
                    Padding="14"
                    Background="{DynamicResource LandingDashboardPanelBrush}"
                    BorderBrush="{DynamicResource LandingDashboardPanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14">
                    <TextBlock Style="{StaticResource DashboardMutedTextStyle}" Text="{Binding StatusMessage}" />
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
