<UserControl
    x:Class="Open.Db.Viewer.Shell.Views.Navigation.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="720">
            <Border
                Padding="24"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                BorderThickness="1"
                CornerRadius="20">
                <StackPanel>
                    <TextBlock
                        FontSize="28"
                        FontWeight="SemiBold"
                        Text="{Binding Title}" />
                    <TextBlock
                        Margin="0,12,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="设置保存在本机 LocalAppData\OpenDbViewer\settings.json。"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Margin="0,8,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding StatusMessage}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border
                Margin="0,16,0,0"
                Padding="24"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                BorderThickness="1"
                CornerRadius="20">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="外观" />
                    <TextBlock
                        Margin="0,8,0,12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding ThemeSummary}"
                        TextWrapping="Wrap" />
                    <WrapPanel>
                        <ui:Button
                            Margin="0,0,8,8"
                            Command="{Binding SetThemeSystemCommand}"
                            Content="跟随系统" />
                        <ui:Button
                            Margin="0,0,8,8"
                            Command="{Binding SetThemeLightCommand}"
                            Content="浅色" />
                        <ui:Button
                            Margin="0,0,8,8"
                            Command="{Binding SetThemeDarkCommand}"
                            Content="深色" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border
                Margin="0,16,0,0"
                Padding="24"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                BorderThickness="1"
                CornerRadius="20">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="查询保护" />
                    <TextBlock
                        Margin="0,8,0,4"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="查询结果最大行数（超出将截断并提示）" />
                    <ComboBox
                        Width="200"
                        HorizontalAlignment="Left"
                        ItemsSource="{Binding QueryMaxResultRowsOptions}"
                        SelectedItem="{Binding QueryMaxResultRows, Mode=TwoWay}" />
                    <TextBlock
                        Margin="0,16,0,4"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="查询超时" />
                    <ComboBox
                        Width="200"
                        HorizontalAlignment="Left"
                        ItemsSource="{Binding QueryTimeoutSecondsOptions}"
                        SelectedItem="{Binding QueryTimeoutSeconds, Mode=TwoWay}" />
                    <TextBlock
                        Margin="0,8,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding QueryTimeoutLabel}" />
                </StackPanel>
            </Border>

            <Border
                Margin="0,16,0,24"
                Padding="24"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
                BorderThickness="1"
                CornerRadius="20">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="数据页默认" />
                    <TextBlock
                        Margin="0,8,0,4"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="默认每页行数" />
                    <ComboBox
                        Width="200"
                        HorizontalAlignment="Left"
                        ItemsSource="{Binding PageSizeOptions}"
                        SelectedItem="{Binding DefaultPageSize, Mode=TwoWay}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
