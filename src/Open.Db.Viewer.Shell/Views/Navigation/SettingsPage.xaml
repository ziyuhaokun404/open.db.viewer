<UserControl
    x:Class="Open.Db.Viewer.Shell.Views.Navigation.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Margin="24">
        <Border
            Padding="24"
            Background="{DynamicResource ControlFillColorSecondaryBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorSecondaryBrush}"
            BorderThickness="1"
            CornerRadius="20"
            VerticalAlignment="Top">
            <StackPanel>
                <TextBlock
                    FontSize="28"
                    FontWeight="SemiBold"
                    Text="{Binding Title}" />
                <TextBlock Margin="0,12,0,0" Text="切换应用外观，主页、列表页和数据库工作区都会跟着一起切换。" />
                <TextBlock
                    Margin="0,16,0,0"
                    FontWeight="SemiBold"
                    Text="{Binding ThemeSummary}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
